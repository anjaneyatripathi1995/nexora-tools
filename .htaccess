# Nexora Tools — Root .htaccess
# Used on XAMPP where the project lives at /nexora-tools/ inside htdocs.
# On Hostinger (production), public_html/ IS the document root, so this file
# is NOT used — the public/.htaccess handles everything there.

<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On

    # ── Static assets: serve from public/ sub-directories ────────────────────
    # Allows browser requests like /nexora-tools/assets/css/style.css to find
    # the actual file at /nexora-tools/public/assets/css/style.css

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^assets/(.*)$  public/assets/$1  [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^build/(.*)$   public/build/$1   [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^images/(.*)$  public/images/$1  [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^tools/([^/]+)/assets/(.*)$  public/tools/$1/assets/$2  [L]

    # ── Everything else → hybrid front controller ─────────────────────────────
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L]
</IfModule>
