##############################################################################
# Nexora Tools — Hostinger Production .env
#
# HOW TO DEPLOY ON HOSTINGER SHARED HOSTING:
# 1. Upload ALL project files to: /home/<user>/nexora-tools/
#    (NOT inside public_html — keep them private)
# 2. Upload ONLY the contents of the local public/ folder to: /home/<user>/public_html/
#    (index.php, .htaccess, assets/, build/, images/, tools/)
# 3. Copy this file to /home/<user>/nexora-tools/.env  (rename to .env)
# 4. Fill in your DB credentials below
# 5. Generate a new APP_KEY:  php artisan key:generate
# 6. Run migrations:          php artisan migrate --force
# 7. Clear ALL caches (run after every deployment):
#       php artisan config:clear
#       php artisan view:clear
#       php artisan route:clear
#       php artisan cache:clear
#       php artisan optimize:clear
#
# ─── COMMON 500 ERROR CAUSES ─────────────────────────────────────────────────
# • Wrong DB credentials          → check DB_* values below
# • SESSION_DRIVER=database with  → sessions table missing; use SESSION_DRIVER=file
#   missing sessions table          (safest for shared hosting)
# • Stale compiled views          → run php artisan view:clear
# • Missing vendor/               → run composer install --no-dev
# • Missing APP_KEY               → run php artisan key:generate
# • Wrong APP_URL                 → must match your actual domain exactly
# • Missing public/build/         → upload public/build/ from local after npm run build
##############################################################################

APP_NAME="Nexora Tools"
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_OUTPUT_OF_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://tripathinexora.com

# APP_PUBLIC_PATH is NOT needed — the public path is auto-detected from
# the index.php location (public_html/index.php → public_html/).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

##############################################################################
# DATABASE — use your Hostinger MySQL credentials
##############################################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_hostinger_db_name
DB_USERNAME=your_hostinger_db_user
DB_PASSWORD=your_hostinger_db_password

# SESSION_DRIVER=file is the safest choice for Hostinger shared hosting.
# Using "database" requires the sessions table to exist AND the DB to be reachable
# on EVERY page load — if either fails, ALL pages return 500.
# Switch back to "database" only after confirming DB + sessions table work.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

##############################################################################
# MAIL — use Hostinger's SMTP
##############################################################################
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@tripathinexora.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@tripathinexora.com"
MAIL_FROM_NAME="Nexora Tools"

VITE_APP_NAME="${APP_NAME}"
