# ─── Dependencies ──────────────────────────────────────────────────────────
/vendor/
/node_modules/
/old_techhub/

# ─── Environment & Secrets ────────────────────────────────────────────────
.env
.env.backup
.env.production
.env.*.local

# ─── Vite build output (committed for Hostinger — see note below) ─────────
# public/build IS committed so Hostinger (no Node.js) gets compiled assets.
# To re-enable ignoring: uncomment the line below.
# /public/build

# Vite dev-server hot-reload flag — NEVER commit this.
# When present, @vite ignores the manifest and streams from the dev server (port 5173).
# If the dev server is not running, all assets get ERR_CONNECTION_REFUSED.
/public/hot

# ─── Logs & Cache ─────────────────────────────────────────────────────────
*.log
/logs/
/tmp/
/.cache/
/debug-*.log
/bootstrap/cache/*.php
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/
/storage/logs/

# ─── OS / IDE ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
/.idea
/.vscode
/.fleet

# ─── Reference / archive (old codebase kept for reference only) ────────────
/old_techhub/
